set policy-options policy-statement policy.name term FULL from route-filter 0.0.0.0/0 prefix-length-range /0-/24
set policy-options policy-statement policy.name term FULL then accept
set policy-options policy-statement policy.name term REJECT then reject
set protocols bgp group BGP.NAME export policy.name
set routing-options static route 0.0.0.0/0 discard
